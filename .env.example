HOST=0.0.0.0
PORT=8787

ASR_MODEL_DIR=./models/sherpa-onnx-paraformer-zh-2024-03-09
ASR_SAMPLE_RATE=16000
ASR_ENDPOINT_SILENCE_MS=800

LLM_API_KEY=
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_MODEL=mistralai/mistral-small-4-119b-2603
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=1
LLM_TOP_P=1
LLM_TIMEOUT_MS=30000
LLM_TEST_TIMEOUT_MS=30000
LLM_TLS_REJECT_UNAUTHORIZED=true
LLM_TEST_PROMPT=用一句中文介绍你自己。
LLM_TEST_IMAGE_URL=

TTS_VOICE=zh-CN-XiaoxiaoNeural
TTS_RATE=+0%
TTS_FORMAT=audio-24khz-48kbitrate-mono-mp3
TTS_TIMEOUT_MS=10000
TTS_TLS_REJECT_UNAUTHORIZED=true
TTS_TEST_TEXT=Hello, how can I help you today?
TTS_TEST_OUTPUT=./tmp/edge-tts-test.mp3

EXA_API_KEY=
EXA_SEARCH_MAX_RESULTS=5
EXA_SEARCH_TIMEOUT_MS=10000

CLIENT_WS_URL=ws://127.0.0.1:8787/ws
CLIENT_AUDIO_DEVICE=
CLIENT_MUTE_MIC_DURING_TTS=true
CLIENT_UNMUTE_DELAY_MS=500
